# Optional: bake an Anthropic API key into the dev build so you don't have to
# paste it in the app. Copy this file to `.env.local` and fill in your key.
#
#   cp .env.example .env.local
#
# SECURITY NOTE: any VITE_-prefixed variable is embedded in the client bundle
# and visible to anyone who opens devtools. This is fine for local development,
# but a production deployment should proxy Claude API calls through a small
# backend that holds the key server-side.
VITE_ANTHROPIC_API_KEY=
