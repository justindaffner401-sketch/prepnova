# Optional: bake an Anthropic API key into the dev build so you don't have to
# paste it in the app. Copy this file to `.env.local` and fill in your key.
#
#   cp .env.example .env.local
#
# SECURITY NOTE: any VITE_-prefixed variable is embedded in the client bundle
# and visible to anyone who opens devtools. This is fine for local development,
# but a production deployment should proxy Claude API calls through a small
# backend that holds the key server-side.
VITE_ANTHROPIC_API_KEY=

# Supabase (public values — also set these in Vercel for production builds)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only secrets — set in Vercel → Settings → Environment Variables,
# NEVER with a VITE_ prefix:
#   ANTHROPIC_API_KEY        Claude key for /api/generate-questions
#   SUPABASE_URL             same as VITE_SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY Supabase service role (Settings → API)
#   STRIPE_SECRET_KEY        sk_test_... or sk_live_...
#   STRIPE_PRICE_ID          price_... for the $29/mo subscription
#   STRIPE_WEBHOOK_SECRET    whsec_... from the webhook endpoint
